# SP1 Groth16 verifier gateway address (varies by network).
# This Sepolia gateway routes v6.1.x Groth16 proofs after the sp1-contracts v6.1.1 update.
SP1_VERIFIER_ADDRESS=0x397A5f7f3dBd538f23DE225B51f532c34448dA9B

# Your program's verification key (get from `cargo run --release --bin vkey`)
TX_INCLUSION_PROGRAM_VKEY=0x00ef99aa9ca5343648ec4bf880180e8f9a05d8be759659925cec813035acf507

# Deployer private key used to pay deployment gas (without 0x prefix for Foundry)
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_without_0x_prefix

# Owner private key for owned contract permissions (without 0x prefix for Foundry)
OWNER_PRIVATE_KEY=your_owner_private_key_without_0x_prefix

# Etherscan API key (for verification)
ETHERSCAN_API_KEY=your_api_key_here
